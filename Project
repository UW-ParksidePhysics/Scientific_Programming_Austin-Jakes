#Planar Grid
def draw_planar_grid(circle_spacing, spoke_angle, max_radius=3.0, grid_color='white'):
    """
    Draw a simple planar reference grid in the x-y plane (z = 0),
    using concentric circles and radial spokes.
    
    Parameters
    ----------
    circle_spacing : float
        Spacing between circles, in plot units (parsecs).
    spoke_angle : float
        Angle between spokes, in degrees.
    max_radius : float, optional
        radius of largest circle, in parsecs
    grid_color : string, optional
        sets color of grid
    """
    ax = plt.gca()

    
    theta = np.linspace(0, 2 * np.pi, 400)

    radius = circle_spacing
    while radius <= max_radius:
        x = radius * np.cos(theta)
        y = radius * np.sin(theta)
        z = np.zeros_like(theta)
        ax.plot(x, y, z, linewidth=0.8, alpha=0.5, color=grid_color)
        radius += circle_spacing

    for angle_deg in np.arange(0, 360, spoke_angle):
        angle_rad = np.radians(angle_deg)
        x = np.array([0, max_radius * np.cos(angle_rad)])
        y = np.array([0, max_radius * np.sin(angle_rad)])
        z = np.array([0, 0])
        ax.plot(x, y, z, linewidth=0.6, alpha=0.4, color=grid_color)



