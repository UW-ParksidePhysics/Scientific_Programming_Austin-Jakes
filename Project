#adjustable parallax
def get_star_information(parallax=500.0):
    from astroquery.simbad import Simbad 
    query = f"""
SELECT 
    b.main_id,
    b.ra, 
    b.dec,   
    b.plx_value,
    fb.flux AS B_mag,
    fv.flux AS V_mag
FROM basic AS b
JOIN flux AS fb 
    ON b.oid = fb.oidref AND fb.filter = 'B'
JOIN flux AS fv 
    ON b.oid = fv.oidref AND fv.filter = 'V'        
WHERE b.otype = 'star..'
  AND b.plx_value >= {parallax}
"""
    return Simbad.query_tap(query)


